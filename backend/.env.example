# Copy to .env. Never commit real secrets.

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# Local Postgres example:
# DATABASE_URL=postgresql+asyncpg://culture:culture@localhost:5432/culture
# Render Postgres provides a standard postgresql:// URL; the app normalizes it to
# postgresql+asyncpg:// automatically for SQLAlchemy's async engine.

# --- API meta ---
ENVIRONMENT=development
API_VERSION=1.0.0

# --- CORS: include EVERY origin your Next.js dev server prints (e.g. 3000 or 3001) ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
# Optional: allow preview deployments (example)
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# --- Search (serpapi | google_cse | mock) ---
# Default is serpapi: set SERPAPI_API_KEY for real Google results. Without a key, API falls back to mock (fixture data).
SEARCH_PROVIDER=serpapi
SERPAPI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# --- LLM (openai_compatible | mock) — mock needs no keys ---
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Scraping ---
HTTP_TIMEOUT_SECONDS=20
MAX_SEARCH_QUERIES=12
MAX_URLS_TO_SCRAPE=22
MAX_EXTRACT_CHARS_PER_PAGE=12000
RESPECT_ROBOTS_TXT=true
PLAYWRIGHT_ENABLED=false
PLAYWRIGHT_TIMEOUT_MS=30000

# --- Cache & limits ---
REPORT_CACHE_TTL_HOURS=24
RESEARCH_RATE_LIMIT_PER_MINUTE=8

DEBUG=false
